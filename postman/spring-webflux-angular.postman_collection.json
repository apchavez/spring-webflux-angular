          "name": "POST Crear producto — 201 Created",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response tiene id generado', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.collectionVariables.set('productId', body.id);",
                  "});",
                  "pm.test('Campos de respuesta son correctos', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.sku).to.eql('SKU-100');",
                  "    pm.expect(body.name).to.eql('Wireless Mouse');",
                  "    pm.expect(body.price).to.eql(29.99);",
                  "    pm.expect(body.active).to.eql(true);",
                  "});",
                  "pm.test('Content-Type es application/json', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
