      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response contiene un token', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('adminToken', body.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Usuarios demo (DemoUserStore.java): admin/admin123 (ADMIN), user/user123 (USER). Captura el JWT en la variable de colección `adminToken`, usada como Bearer auth por el resto de la colección — correr esta request primero."
          },
